      </xs:complexType>
      <xs:complexType name="ReklamationListeType">
        <xs:sequence>
          <xs:element name="Produkt" type="ReklamationType" minOccurs="1" maxOccurs="unbounded" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="BestellungType">
        <xs:sequence>
          <xs:element name="Lieferant" type="xs:string" />
          <xs:element name="Bestellung" type="ProduktlisteType" />
        </xs:sequence>
      </xs:complexType>
    </xs:schema>
