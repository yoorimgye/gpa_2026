    <xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
      <xs:simpleType name="AblehnungType">
        <xs:restriction base="xs:string">
          <xs:enumeration value="Das Produkt ist defekt." />
          <xs:enumeration value="Es wurde ein falsches Produkt geliefert." />
          <xs:enumeration value="Es wurde zu wenig geliefert." />
          <xs:enumeration value="Die Produktqualität ist minderwertig." />
          <xs:enumeration value="Das Produkt ist abgelaufen." />
        </xs:restriction>
      </xs:simpleType>
      <xs:complexType name="ItemType">
        <xs:sequence>
          <xs:element name="ProduktType" type="xs:string" />
          <xs:element name="Anzahl" type="xs:positiveInteger" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ProduktlisteType">
        <xs:sequence>
          <xs:element name="Produkt" type="ItemType" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
      </xs:complexType>
      <xs:complexType name="ReklamationType">
        <xs:sequence>
          <xs:element name="Produkt" type="xs:string" />
          <xs:element name="Anzahl" type="xs:positiveInteger" />
